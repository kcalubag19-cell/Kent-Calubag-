<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Company Profile Card</title>

    <!-- External CSS -->
    <link rel="stylesheet" href="styles.css">

    <!-- Internal CSS -->
    <style>
        article {
            background: white;
            border-radius: 10px;
            padding: 20px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.2);
            width: 300px;
            text-align: center;
            margin: 20px auto;
        }
    </style>
</head>
<body>

    <!-- HEADER -->
    <header>
        <h1>My Company</h1>
        <p>Your trusted partner in success</p>
    </header>

    <!-- MAIN -->
    <main>
        <article>
            <h2>About Us</h2>
            <p>We are a startup company focused on delivering quality services and innovative solutions.</p>
        </article>
    </main>

    <!-- FOOTER -->
    <footer>
        <p>© 2026 My Company</p>

        <!-- Inline CSS -->
        <button style="background-color: blue; color: white; padding: 10px; border: none; border-radius: 5px;">
            Contact Us
        </button>
    </footer>

</body>
</html>
